# Whitelist approach: ignore everything in root, then explicitly include.
# This folder also holds private/internal material that must NOT be published.

/*
!/.gitignore
!/README.md
!/index.html
!/LICENSE
!/Images/

# Inside whitelisted directories, ignore typical OS/editor noise
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.tmp

# Source-data exports we don't want to publish (CSV/XLSX in Images/)
Images/*.csv
Images/*.xlsx
