# Whitelist approach: ignore everything in root, then explicitly include.
# This folder also holds private/internal material that must NOT be published.

/*
!/.gitignore
!/.env.example
!/README.md
!/index.html
!/LICENSE
!/Images/
!/tools/
!/package.json
!/package-lock.json
!/build-pdf.js
!/12-step-design-primer.pdf
!/.github/

# Inside whitelisted directories, ignore typical OS/editor noise
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.tmp

# Source-data exports we don't want to publish (CSV/XLSX in Images/)
Images/*.csv
Images/*.xlsx

# Personal working notes — do not publish
Images/Joes Build Notes.md

# Secrets — NEVER commit (your real key lives here)
.env

# Python build/cache artifacts inside tools/
tools/__pycache__/
tools/.venv/
tools/*.pyc

# Node / Puppeteer build artifacts (only the generated PDF is committed)
node_modules/
